# ─── AIR.MS SAP HANA connection ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

AIRMS_HOST=127.0.0.1
AIRMS_PORT=54321
AIRMS_USER=<your_username>
AIRMS_PASSWORD=<your_password>
AIRMS_DATABASE=AIRMS
AIRMS_ENCRYPT=TRUE
AIRMS_SSL_VALIDATE_CERTIFICATE=FALSE
AIRMS_SSL_HOSTNAME_IN_CERT=hana-pa2.mssm.edu
AIRMS_SSL_TRUSTSTORE=None
AIRMS_CONNECT_TIMEOUT=0
