# Copy to ".env" and adjust as needed: cp .env.example .env
#
# Pinned INCEpTION version (image tag and standalone JAR version).
INCEPTION_VERSION=40.6

# Host port to expose the web UI on.
INCEPTION_PORT=8080

# Database credentials used by both the db and app containers.
DBUSER=inception
DBPASSWORD=change-me-in-production

# Optional: override the image (e.g. a private mirror).
# INCEPTION_IMAGE=ghcr.io/inception-project/inception

# Optional: bind-mount host paths instead of named volumes.
# INCEPTION_HOME=./app-data
# INCEPTION_DB_HOME=./db-data
